{
  "name": "immich-sync",
  "version": "0.0.1",
  "description": "Tauri app: watch folders and upload media to Immich",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
